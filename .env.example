# Base de datos - PostgreSQL (Neon)
# Obtener desde: https://console.neon.tech → Connection string
# Usar la opción "Pooled connection" (host con -pooler) para evitar errores de conexión cerrada.
# Ejemplo: ...@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# La app añade connection_limit=1 y connect_timeout=15 si no están en la URL.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth.js v5 - IMPORTANTE para Vercel
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"
AUTH_SECRET="generar-con-openssl-rand-base64-32"
# Local:
NEXTAUTH_URL="http://localhost:3000"
# En Vercel: usar la URL de producción, ej: NEXTAUTH_URL="https://sistemagestion-xxx.vercel.app"

# Nombre público de la aplicación
NEXT_PUBLIC_APP_NAME="Sistema de Gestión"

# Vercel Blob (almacenamiento de archivos)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
